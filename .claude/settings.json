{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(xcodegen generate)",
      "Bash(xcodebuild -project ChillMac.xcodeproj *)",
      "Bash(open *)",
      "Bash(./scripts/build-dmg.sh)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
